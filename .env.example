# Data sources
DUNE_API_KEY=
EXA_API_KEY=
ANTHROPIC_API_KEY=

# Models (configurable; not anchored to a provider/model)
VERITY_SYNTH_MODEL=claude-opus-4-8
VERITY_JUDGE_MODEL=claude-haiku-4-5-20251001

# Telemetry
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Mantle / ERC-8004 — registry addresses confirmed live on Mantle mainnet (chainId 5000)
# via eth_getCode on 2026-06-18; deterministic CREATE2 vanity deployments.
MANTLE_RPC_URL=https://rpc.mantle.xyz
VERITY_PRIVATE_KEY=
ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_VALIDATION_REGISTRY=0x8004Cc8439f36fd5F9F049D9fF86523Df6dAAB58
# Register the agent in the Identity Registry first — run:
#   npx tsx src/attest-8004/register.ts [agentURI]
# That mints the agentId (ERC-721 tokenId) and prints the values to paste below.
VERITY_AGENT_URI=https://github.com/your-handle/verity
VERITY_AGENT_ID=
VERITY_VALIDATOR_ADDRESS=
