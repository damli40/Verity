# Data sources
DUNE_API_KEY=
EXA_API_KEY=

# LLM provider: "anthropic" (default) or "openai". Set the matching key + model names below.
VERITY_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Models (configurable; not anchored to a provider/model).
# For OpenAI testing: VERITY_LLM_PROVIDER=openai and set these to OpenAI model names.
VERITY_SYNTH_MODEL=claude-opus-4-8
VERITY_JUDGE_MODEL=claude-haiku-4-5-20251001

# Set to 1 to run the REAL synthesizer + judge over cached fixture data (test the LLM path
# without Dune/Exa keys): VERITY_FIXTURE_LIVE_LLM=1 npx tsx src/cli.ts --fixture
VERITY_FIXTURE_LIVE_LLM=

# Live run config (non-fixture path)
# Comma-separated saved/public Dune query IDs the run verifies claims against.
VERITY_QUERY_IDS=
# Comma-separated URLs to scrape for corroboration figures (must be on data/source-allowlist.json
# with the "corroboration" role to admit a number). Domain is derived from the URL host.
VERITY_SCRAPE_URLS=

# Telemetry
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Mantle / ERC-8004 — registry addresses confirmed live on Mantle mainnet (chainId 5000)
# via eth_getCode on 2026-06-18; deterministic CREATE2 vanity deployments.
MANTLE_RPC_URL=https://rpc.mantle.xyz
VERITY_PRIVATE_KEY=
ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_VALIDATION_REGISTRY=0x8004Cc8439f36fd5F9F049D9fF86523Df6dAAB58
# Register the agent in the Identity Registry first — run:
#   npx tsx src/attest-8004/register.ts [agentURI]
# That mints the agentId (ERC-721 tokenId) and prints the values to paste below.
VERITY_AGENT_URI=https://github.com/damli40/Verity
VERITY_AGENT_ID=
VERITY_VALIDATOR_ADDRESS=
